# Supabase (required for auth and data)
# Get these from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Google Maps (for therapist location map)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Gemini (for AI chat, voice note structuring, and audio transcription)
# Get a free API key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
# Optional: override model (default: gemini-2.5-flash). Try gemini-2.0-flash if 2.5 is unavailable.
# GEMINI_MODEL=gemini-2.5-flash

# Stripe (for payments)
# Get these from Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...   # From Stripe CLI or Dashboard webhooks
# Optional: Stripe Connect (therapist payouts)
# STRIPE_CONNECT_CLIENT_ID=ca_...

# Required for Stripe webhook (server-only; never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Zoom (create video meetings from appointments)
# Create a Server-to-Server OAuth app at https://marketplace.zoom.us/ then add credentials.
# Required: ZOOM_ACCOUNT_ID, ZOOM_CLIENT_ID, ZOOM_CLIENT_SECRET
# ZOOM_ACCOUNT_ID=your-account-id
# ZOOM_CLIENT_ID=your-client-id
# ZOOM_CLIENT_SECRET=your-client-secret
# Optional: ZOOM_USER_ID – Zoom user ID or email to create meetings as (default: first active user)

# Appointment reminders (cron-triggered)
# RESEND_API_KEY=re_...           # From resend.com – required for email reminders
# REMINDER_HOURS_BEFORE=24        # Send reminder this many hours before appointment (default 24)
# CRON_SECRET=your-secret         # Protect /api/cron/reminders (e.g. Vercel Cron sends this header)
# Optional: SMS reminders (Twilio)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890
# REMINDER_FROM_EMAIL=reminders@yourdomain.com  # Verified domain in Resend
